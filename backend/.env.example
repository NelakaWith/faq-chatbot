# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/
# Google: Gemma 3 27B (free)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_REFERER=your_referer_here
OPENROUTER_TITLE=your_title_here

# Gemini API Configuration
# Get your API key from https://developers.generativeai.google/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=your_gemini_model_name_here
GOOGLE_BASE_URL=your_google_base_url_here

# Groq API Configuration
# Get your API key from https://www.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=your_groq_model_name_here
GROQ_BASE_URL=your_groq_base_url_here
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=1024